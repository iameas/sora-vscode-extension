{
    "name": "sora-extension",
    "displayName": "Sora",
    "description": "A Visual Studio Code extension for the Sora Programming Languague, designed for easy cross-platform app development.",
    "version": "1.0.0",
    "publisher": "iameas",
    "engines": {
        "vscode": "^1.22.0"
    },
    "categories": [
        "Programming Languages",
        "Linters",
        "Debuggers",
        "Formatters",
        "Snippets",
        "Others"
    ],
    "icon": "assets/icon.png",
    "repository":{
        "type": "git",
        "url": "https://github.com/iameas/sora-vscode-extension"
    },
    "homepage": "https://github.com/iameas/sora-vscode-extension",
    "bugs": {
        "url": "https://github.com/iameas/sora-vscode-extension/issues"
    },
    "keywords": [
        "Sora",
        "Languague",
        "Extension",
        "SDK",
        "CLI",
        "Cross-platform"
    ],
    "activationEvents": [
        "onLanguage:sora",
        "onCommand:sora.initProject",
        "onCommand:sora.buildApp",
        "onCommand:sora.runApp",
        "onCommand:sora.deployApp",
        "workspaceContains:**/*.sora"
    ],
    "main": "./out/extension.js",
    "contributes": {
        "languages": [
            {
                "id": "sora",
                "aliases": ["Sora", "sora"],
                "extensions": [
                    ".sora"
                ],
                "configuration": "./language-configuration.json"
            }
        ],
        "grammars": [
            {
                "language": "sora",
                "scopeName": "source.sora",
                "path": "./syntaxes/sora.tmLanguage.json"
            }
        ],
        "commands": [
            {
                "command": "sora.initProject",
                "title": "Sora: Initialize New Project",
                "category": "Sora"
            },
            {
                "command": "sora.buildApp",
                "title": "Sora: Build Appplication",
                "category": "Sora"
            },
            {
                "command": "sora.runApp",
                "title": "Sora: Run Appplication",
                "category": "Sora"
            },
            {
                "command": "sora.deployApp",
                "title": "Sora: Deploy Appplication",
                "category": "Sora"
            }
        ],
        "keybindings":[
            {
                "command": "sora.initProject",
                "key": "ctrl+alt+i",
                "mac": "cmd+alt+i",
                "when": "editorTextFocus"
            },
            {
                "command": "sora.buildApp",
                "key": "ctrl+alt+b",
                "mac": "cmd+alt+b",
                "when": "editorTextFocus"
            },
            {
                "command": "sora.runApp",
                "key": "ctrl+alt+r",
                "mac": "cmd+alt+r",
                "when": "editorTextFocus"
            },
            {
                "command": "sora.deployApp",
                "key": "ctrl+alt+d",
                "mac": "cmd+alt+d",
                "when": "editorTextFocus"
            }
        ],
        "snippets": [
            {
                "language": "sora",
                "path": "./snippets/sora.code-snippets.json"
            }
        ],
        "configurationDefaults": {
            "[sora]": {
                "editor.formatOnSave": true
            }
        },
        "menus": {
            "commandPalette": [
                {
                    "command": "sora.initProject",
                    "when": "editorTextFocus"
                },
                {
                    "command": "sora.buildApp",
                    "when": "editorTextFocus"
                },
                {
                    "command": "sora.runApp",
                    "when": "editorTextFocus"
                },
                {
                    "command": "sora.deployApp",
                    "when": "editorTextFocus"
                }
            ]
        }
    },
    "scripts": {
        "vscode:prepublish": "tsc -p ./",
        "compile": "tsc -p ./",
        "watch": "tsc -w -p ./"
    },
    "devDependencies": {
        "@types/vscode":  "^1.22.0",
        "typescript": "^4.0.0",
        "eslint": "^8.0.0",
        "prettier": "^2.3.2",
        "@typescript-eslint/eslint-plugin": "^4.28.2",
        "@typescript-eslint/parser": "^4.28.2"
    },
    "dependencies": {
        "prettier-plugin-sora": "^1.0.0"
    }
}
